# Copy this file to .env and fill in the values for your machine.
# .env is gitignored; .env.example is committed as documentation.

# Absolute path to the Cocos project (the folder containing assets/, project.json, etc.)
CC_PROJECT_PATH=D:\cocos\hello

# Absolute path to the CocosCreator 2.4 executable
# Windows default installed via Cocos Dashboard:
CC_CREATOR_PATH=C:\ProgramData\cocos\editors\Creator\2.4.15\CocosCreator.exe
# macOS:
# CC_CREATOR_PATH=/Applications/CocosCreator/2.4.15/CocosCreator.app/Contents/MacOS/CocosCreator

# --- Windows build ---
# Visual Studio configuration: Debug | Release
WIN_CONFIG=Release
# MSBuild platform: Win32 | x64
WIN_ARCH=Win32
# C++ platform toolset: v142 (VS 2019) | v143 (VS 2022)
WIN_TOOLSET=v142

# --- Android build ---
# ANDROID_KEYSTORE_PATH=D:\keys\release.keystore
# ANDROID_KEYSTORE_PWD=
# ANDROID_KEY_ALIAS=
# ANDROID_KEY_PWD=

# --- iOS / macOS build ---
# IOS_SCHEME=YourGame
# IOS_WORKSPACE=YourGame.xcworkspace
# MAC_SCHEME=YourGame
