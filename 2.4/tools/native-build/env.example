# 复制为 .env 并根据实际项目修改，然后在运行脚本前 `source .env` (mac/linux)
# 或用 `set` (windows cmd) / 用 dotenv-cli 加载。config.mjs 里都做了默认值兜底。

# 通用
CC_PROJECT_PATH=D:/cocos/hello
CC_CREATOR_PATH=C:/ProgramData/cocos/editors/Creator/2.4.15/CocosCreator.exe

# Android 签名
ANDROID_KEYSTORE_PATH=
ANDROID_KEYSTORE_PWD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PWD=

# iOS
IOS_SCHEME=YourGame
IOS_WORKSPACE=
IOS_EXPORT_PLIST=

# macOS
MAC_SCHEME=YourGame
MAC_EXPORT_PLIST=

# Windows
WIN_CONFIG=Debug
WIN_ARCH=Win32
